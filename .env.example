# PostgreSQL
DB_HOST=postgres
DB_USERNAME=bpmadmin
DB_PASSWORD=bpmadmin

# Connection pools
HIKARI_MAX_POOL=20
HIKARI_MIN_IDLE=5

# JWT
JWT_SECRET=CHANGE_ME_bpm_platform_jwt_secret_key_2026_min_256bits
JWT_EXPIRATION_MS=86400000

# Zeebe (SaaS) - deshabilitado por defecto
ZEEBE_ENABLED=false
ZEEBE_GATEWAY=localhost:26500
ZEEBE_SECURE=false
ZEEBE_CLIENT_ID=
ZEEBE_CLIENT_SECRET=
ZEEBE_OAUTH_URL=
